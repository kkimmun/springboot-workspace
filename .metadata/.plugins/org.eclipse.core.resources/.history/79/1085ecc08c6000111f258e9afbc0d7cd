<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
  PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
  "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
  
 <mapper namespace="com.kh.semi.board.model.dao.BoardMapper">
  	<insert id="save"
  			parameterType="Board">
  		INSERT
  			INTO
  				SEMI_BOARD
  			VALUES
  				(
				SEQ_SBN.NEXTVAL,
				#{boardTitle},
				#{boardContent},
				#{boardWriter},
				#{fileUrl},
				DEFAULT,
				DEFAULT
				)
  	</insert>
  	
  	<select id="findAll">
  		SELECT
  				BOARD_NO,
  				BOARD_TITLE,
  				BOARD_WRITER,
  				CREATE_DATE
  			FROM
  				SEMI_BOARD
  			WHERE
  				STATUS='Y'
  			ORDER
  				BY
  					CREATE_DATE DESC
  	</select>
 </mapper>
  